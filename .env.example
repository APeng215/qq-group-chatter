DEEPSEEK_API_KEY=

# Local embedding for Mem0.
MEM0_FASTEMBED_MODEL=BAAI/bge-small-zh-v1.5

# Console logging levels: DEBUG, INFO, WARNING, ERROR.
# Project logs from qq_group_chatter.*. Usually keep INFO for message/memory metrics.
QQ_GROUP_CHATTER_LOG_LEVEL=INFO
# Framework logs from NoneBot, Uvicorn, and OneBot adapter. Use INFO to see startup/listening/connection logs; use WARNING to hide routine framework noise.
QQ_GROUP_CHATTER_FRAMEWORK_LOG_LEVEL=INFO
